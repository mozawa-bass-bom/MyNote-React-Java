# ==========================================
# Frontend Environment Variables (Vercel)
# ==========================================
# バックエンドAPIのURL（同一ドメインなら /api 、別プロジェクトなら https://mynote-backend.vercel.app/api）
VITE_API_BASE_URL=http://localhost:8080/api

# ==========================================
# Backend Environment Variables (Vercel / Docker)
# ==========================================
# データベース接続設定 (PlanetScale, Supabase, AWS RDS 等)
DB_URL=jdbc:mysql://<DB_HOST>:3306/<DB_NAME>?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Tokyo
DB_USER=root
DB_PASS=your_production_password

# JWT 署名キー（32文字以上の安全な文字列）
JWT_SECRET=your_jwt_secret_key_change_in_production

# CORS 許可オリジン（フロントエンドの Vercel URL）
CORS_ORIGINS=https://mynote-frontend.vercel.app

# Google Cloud / Vertex AI 設定
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL_ID=gemini-2.5-flash

# Firebase Storage 設定
FIREBASE_BUCKET=your-app.firebasestorage.app
FIREBASE_CONFIG_PATH=keys/firebase-service-account.json

# ポート番号（Vercelにより自動注入。デフォルトは8080）
PORT=8080
